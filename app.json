{
  "expo": {
    "name": "When Baro?",
    "slug": "when-baro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imgs/logo_baro_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/imgs/logo_baro_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.whenbaro.app",
      "versionCode": 1,
      "targetSdkVersion": 35,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/imgs/logo_baro_icon.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "web": {
      "favicon": "./assets/imgs/logo_baro_icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-insights",
      [
        "expo-notifications",
        {
          "icon": "./assets/imgs/logo_baro_notif_icon.png",
          "color": "#FFFFFF"
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_AZURE_FUNCTION_APP_BASE_URL": "https://api.whenbaro.app",
      "eas": {
        "projectId": "379c5464-62fb-4458-9164-4b3d78449fcd"
      }
    }
  }
}
