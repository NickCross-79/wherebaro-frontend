{
  "expo": {
    "name": "wherebaro-frontend",
    "slug": "wherebaro-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_baro.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo_baro.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_baro.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "web": {
      "favicon": "./assets/logo_baro.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store"
    ]
  }
}
