{
  "expo": {
    "name": "When Baro?",
    "slug": "when-baro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imgs/logo_baro.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/imgs/logo_baro.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.wherebaro.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/imgs/logo_baro.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "web": {
      "favicon": "./assets/imgs/logo_baro.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/imgs/logo_baro.png",
          "color": "#D4A574"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5e09dccb-e16d-44a4-8373-696c19716db3"
      },
      "EXPO_PUBLIC_AZURE_FUNCTION_APP_BASE_URL": "https://api.whenbaro.app"
    }
  }
}
